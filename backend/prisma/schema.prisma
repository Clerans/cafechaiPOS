datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              Int                 @id @default(autoincrement())
  email           String              @unique
  passwordHash    String
  firstName       String
  lastName        String
  profileImage    String?
  status          String              @default("ACTIVE") // ACTIVE, INACTIVE
  roleId          Int
  role            Role                @relation(fields: [roleId], references: [id])
  branchId        Int?
  branch          Branch?             @relation(fields: [branchId], references: [id], name: "BranchStaff")
  managedBranches Branch[]            @relation("BranchManager")
  refreshTokens   RefreshToken[]
  transactions    Transaction[]
  cashDrawers     CashDrawerSession[]
  activityLogs    ActivityLog[]
  poCreated       PurchaseOrder[]     @relation("POCreator")
  poApproved      PurchaseOrder[]     @relation("POApprover")
  grnsReceived    GoodsReceivedNote[]
  departmentId    Int?
  department      Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designationId   Int?
  designation     Designation?        @relation(fields: [designationId], references: [id], onDelete: SetNull)
  attendances     Attendance[]
  leaves          Leave[]
  employeeShifts  EmployeeShift[]
  payrolls        Payroll[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique // Super Admin, Admin, Manager, Cashier, Warehouse, HR, Accountant
  description String?
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           // View Products, etc.
  code        String           @unique // view:products, edit:products, etc.
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Branch {
  id           Int                 @id @default(autoincrement())
  name         String
  code         String              @unique
  address      String
  phone        String
  managerId    Int?
  manager      User?               @relation("BranchManager", fields: [managerId], references: [id], onDelete: SetNull)
  users        User[]              @relation("BranchStaff")
  transactions Transaction[]
  expenses     Expense[]
  cashDrawers  CashDrawerSession[]
  products     Product[]
  purchaseOrders PurchaseOrder[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model CompanySettings {
  id            Int      @id @default(autoincrement())
  companyName   String
  logo          String?
  currency      String   @default("USD")
  timezone      String   @default("UTC")
  language      String   @default("en")
  taxRate       Float    @default(0.0)
  receiptFooter String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id              Int                        @id @default(autoincrement())
  name            String
  sku             String                     @unique
  price           Float
  cost            Float
  stock           Int
  threshold       Int                        @default(10) // low stock warning
  expiryDate      DateTime?
  categoryId      Int
  category        Category                   @relation(fields: [categoryId], references: [id])
  brandId         Int?
  brand           Brand?                     @relation(fields: [brandId], references: [id], onDelete: SetNull)
  unitId          Int?
  unit            Unit?                      @relation(fields: [unitId], references: [id], onDelete: SetNull)
  branchId        Int?
  branch          Branch?                    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  images          ProductImage[]
  variants        ProductVariant[]
  batches         Batch[]
  recipes         Recipe[]
  serialNumbers   SerialNumber[]
  movements       StockMovement[]
  adjustmentItems InventoryAdjustmentItem[]
  cycleCountItems CycleCountItem[]
  items           TransactionItem[]
  heldOrderItems  HeldOrderItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  grnItems            GoodsReceivedNoteItem[]
  purchaseReturnItems PurchaseReturnItem[]
  warehouseStocks     WarehouseStock[]
  transferItems       StockTransferItem[]
  productionOrders    ProductionOrder[]
  damagedGoods        DamagedGoods[]
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
}

model Customer {
  id                 Int                 @id @default(autoincrement())
  name               String
  phone              String?             @unique
  email              String?
  groupId            Int?
  group              CustomerGroup?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  membershipLevel    String              @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM
  loyaltyPoints      Int                 @default(0)
  walletBalance      Float               @default(0.0)
  creditLimit        Float               @default(0.0)
  birthday           DateTime?
  notes              String?
  transactions       Transaction[]
  walletTransactions WalletTransaction[]
  campaignLogs       CampaignLog[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt
}

model Transaction {
  id            Int                  @id @default(autoincrement())
  invoiceNumber String               @unique
  total         Float
  cost          Float
  profit        Float
  tax           Float
  discount      Float                @default(0.0)
  serviceCharge Float                @default(0.0)
  couponCode    String?
  status        String               @default("COMPLETED") // COMPLETED, VOIDED, RETURNED
  paymentMethod String               // CASH, CARD, SPLIT, etc.
  orderType     String               // DINE_IN, TAKE_AWAY, DELIVERY
  cashierId     Int
  cashier       User                 @relation(fields: [cashierId], references: [id])
  branchId      Int
  branch        Branch               @relation(fields: [branchId], references: [id])
  customerId    Int?
  customer      Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items         TransactionItem[]
  payments      TransactionPayment[]
  returns       ReturnLog[]
  createdAt     DateTime             @default(now())
}

model TransactionItem {
  id            Int             @id @default(autoincrement())
  transactionId Int
  transaction   Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     Int
  product       Product         @relation(fields: [productId], references: [id])
  variantId     Int?
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity      Int
  price         Float
  cost          Float
}

model Expense {
  id          Int      @id @default(autoincrement())
  amount      Float
  description String
  category    String   // Utilities, Salaries, Rent, Inventory, Marketing, Other
  date        DateTime @default(now())
  branchId    Int
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model CashDrawerSession {
  id             Int       @id @default(autoincrement())
  branchId       Int
  branch         Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  cashierId      Int
  cashier        User      @relation(fields: [cashierId], references: [id])
  openingBalance Float
  closingBalance Float?
  status         String    @default("OPEN") // OPEN, CLOSED
  createdAt      DateTime  @default(now())
  closedAt       DateTime?
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model Brand {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Unit {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  shortName String    @unique
  products  Product[]
}

model ProductVariant {
  id               Int                        @id @default(autoincrement())
  productId        Int
  product          Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku              String                     @unique
  name             String                     // e.g. "Size: Large" or "Color: Brown"
  barcode          String?                    @unique
  price            Float
  cost             Float
  stock            Int
  threshold        Int                        @default(10)
  batches          Batch[]
  serialNumbers    SerialNumber[]
  movements        StockMovement[]
  recipes          Recipe[]
  adjustmentItems  InventoryAdjustmentItem[]
  cycleCountItems  CycleCountItem[]
  transactionItems TransactionItem[]
  heldOrderItems   HeldOrderItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  grnItems            GoodsReceivedNoteItem[]
  purchaseReturnItems PurchaseReturnItem[]
  warehouseStocks     WarehouseStock[]
  transferItems       StockTransferItem[]
  damagedGoods        DamagedGoods[]
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl  String
  isPrimary Boolean @default(false)
}

model Batch {
  id          Int             @id @default(autoincrement())
  productId   Int
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   Int?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  batchNumber String          @unique
  quantity    Int
  cost        Float
  price       Float
  expiryDate  DateTime?
  createdAt   DateTime        @default(now())
}

model RawMaterial {
  id          Int                @id @default(autoincrement())
  name        String             @unique
  sku         String             @unique
  unit        String             // e.g. "kg", "grams", "liter"
  stock       Float              @default(0.0)
  cost        Float
  ingredients RecipeIngredient[]
  createdAt   DateTime           @default(now())
}

model Recipe {
  id          Int                @id @default(autoincrement())
  productId   Int
  product     Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   Int?
  variant     ProductVariant?    @relation(fields: [variantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  ingredients RecipeIngredient[]
  createdAt   DateTime           @default(now())
}

model RecipeIngredient {
  id            Int         @id @default(autoincrement())
  recipeId      Int
  recipe        Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rawMaterialId Int
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  quantityUsed  Float
}

model SerialNumber {
  id           Int             @id @default(autoincrement())
  productId    Int
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId    Int?
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  serialNumber String          @unique
  status       String          @default("IN_STOCK") // IN_STOCK, SOLD, DAMAGED
  createdAt    DateTime        @default(now())
}

model StockMovement {
  id             Int             @id @default(autoincrement())
  productId      Int
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId      Int?
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  type           String          // IN, OUT, ADJUSTMENT, TRANSFER
  quantity       Int
  sourceBranchId Int?
  targetBranchId Int?
  userId         Int
  reason         String?
  createdAt      DateTime        @default(now())
}

model InventoryAdjustment {
  id        Int                       @id @default(autoincrement())
  reason    String
  type      String                    // INCREASE, DECREASE
  userId    Int
  items     InventoryAdjustmentItem[]
  createdAt DateTime                  @default(now())
}

model InventoryAdjustmentItem {
  id           Int                  @id @default(autoincrement())
  adjustmentId Int
  adjustment   InventoryAdjustment  @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  productId    Int
  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId    Int?
  variant      ProductVariant?      @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity     Int
  cost         Float
}

model CycleCount {
  id        Int              @id @default(autoincrement())
  title     String
  status    String           @default("DRAFT") // DRAFT, COMPLETED
  countedBy String
  items     CycleCountItem[]
  createdAt DateTime         @default(now())
}

model CycleCountItem {
  id           Int             @id @default(autoincrement())
  countId      Int
  count        CycleCount      @relation(fields: [countId], references: [id], onDelete: Cascade)
  productId    Int
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId    Int?
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  systemStock  Int
  countedStock Int
}

model TransactionPayment {
  id            Int         @id @default(autoincrement())
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  method        String      // CASH, CARD, BANK_TRANSFER, QR_PAYMENT, GIFT_CARD, STORE_CREDIT
  amount        Float
}

model HeldOrder {
  id            Int             @id @default(autoincrement())
  invoiceNumber String          @unique
  total         Float
  tax           Float
  discount      Float
  serviceCharge Float
  notes         String?
  customerId    Int?
  branchId      Int
  cashierId     Int
  items         HeldOrderItem[]
  createdAt     DateTime        @default(now())
}

model HeldOrderItem {
  id          Int             @id @default(autoincrement())
  heldOrderId Int
  heldOrder   HeldOrder       @relation(fields: [heldOrderId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   Int?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity    Int
  price       Float
  cost        Float
}

model GiftCard {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  balance    Float
  isActive   Boolean   @default(true)
  expiryDate DateTime?
  createdAt  DateTime  @default(now())
}

model ReturnLog {
  id            Int         @id @default(autoincrement())
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  refundAmount  Float
  reason        String
  returnedItems Json        // Array of items returned
  createdAt     DateTime    @default(now())
}

model Supplier {
  id          Int               @id @default(autoincrement())
  name        String
  code        String            @unique
  contactName String?
  email       String?
  phone       String?
  address     String?
  orders      PurchaseOrder[]
  payments    SupplierPayment[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model PurchaseOrder {
  id            Int                 @id @default(autoincrement())
  poNumber      String              @unique
  supplierId    Int
  supplier      Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  branchId      Int
  branch        Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  status        String              @default("PENDING") // PENDING, APPROVED, REJECTED, RECEIVED
  totalAmount   Float
  notes         String?
  createdBy     Int
  creator       User                @relation("POCreator", fields: [createdBy], references: [id])
  approvedBy    Int?
  approver      User?               @relation("POApprover", fields: [approvedBy], references: [id])
  attachments   String?             // JSON list of URLs or paths
  items         PurchaseOrderItem[]
  grns          GoodsReceivedNote[]
  returns       PurchaseReturn[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model PurchaseOrderItem {
  id              Int             @id @default(autoincrement())
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       Int
  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId       Int?
  variant         ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity        Int
  costPrice       Float
}

model GoodsReceivedNote {
  id              Int                    @id @default(autoincrement())
  grnNumber       String                 @unique
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder          @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receivedById    Int
  receiver        User                   @relation(fields: [receivedById], references: [id])
  receivedDate    DateTime               @default(now())
  status          String                 @default("COMPLETED") // PARTIAL, COMPLETED
  items           GoodsReceivedNoteItem[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}

model GoodsReceivedNoteItem {
  id        Int               @id @default(autoincrement())
  grnId     Int
  grn       GoodsReceivedNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  productId Int
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId Int?
  variant   ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity  Int
}

model PurchaseReturn {
  id              Int                  @id @default(autoincrement())
  returnNumber    String               @unique
  purchaseOrderId Int
  purchaseOrder   PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  totalRefund     Float
  reason          String
  items           PurchaseReturnItem[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model PurchaseReturnItem {
  id        Int             @id @default(autoincrement())
  returnId  Int
  return    PurchaseReturn  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productId Int
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity  Int
}

model SupplierPayment {
  id            Int      @id @default(autoincrement())
  paymentNumber String   @unique
  supplierId    Int
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  amount        Float
  paymentMethod String   // CASH, CARD, BANK_TRANSFER
  referenceNo   String?
  paymentDate   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CustomerGroup {
  id              Int        @id @default(autoincrement())
  name            String     @unique
  discountPercent Float      @default(0.0)
  customers       Customer[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model WalletTransaction {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String   // DEPOSIT, WITHDRAWAL, CREDIT_CHARGE, CREDIT_REFUND
  amount     Float
  reference  String?
  createdAt  DateTime @default(now())
}

model Campaign {
  id              Int           @id @default(autoincrement())
  title           String
  type            String        // SMS, EMAIL
  message         String
  discountPercent Float?
  couponCode      String?
  logs            CampaignLog[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model CampaignLog {
  id         Int      @id @default(autoincrement())
  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status     String   // SENT, FAILED
  sentAt     DateTime @default(now())
}

model Warehouse {
  id               Int               @id @default(autoincrement())
  name             String
  code             String            @unique
  address          String?
  phone            String?
  stocks           WarehouseStock[]
  transfersFrom    StockTransfer[]   @relation("FromWarehouse")
  transfersTo      StockTransfer[]   @relation("ToWarehouse")
  productionOrders ProductionOrder[]
  damagedGoods     DamagedGoods[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt
}

model WarehouseStock {
  id          Int             @id @default(autoincrement())
  warehouseId Int
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   Int?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt
}

model StockTransfer {
  id             Int                 @id @default(autoincrement())
  transferNumber String              @unique
  fromWarehouseId Int
  fromWarehouse  Warehouse           @relation("FromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Cascade)
  toWarehouseId   Int
  toWarehouse    Warehouse           @relation("ToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Cascade)
  status         String              // PENDING, APPROVED, COMPLETED, CANCELLED
  notes          String?
  createdBy      Int
  approvedBy     Int?
  items          StockTransferItem[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @default(now()) @updatedAt
}

model StockTransferItem {
  id         Int             @id @default(autoincrement())
  transferId Int
  transfer   StockTransfer   @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  Int?
  variant    ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity   Int
}

model ProductionOrder {
  id          Int       @id @default(autoincrement())
  orderNumber String    @unique
  productId   Int
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int
  status      String    // PENDING, COMPLETED, CANCELLED
  warehouseId Int
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
}

model DamagedGoods {
  id          Int             @id @default(autoincrement())
  warehouseId Int
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId   Int?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity    Int
  reason      String?
  loggedBy    Int
  createdAt   DateTime        @default(now())
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String   @unique
  employees User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Designation {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  employees User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Attendance {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clockIn   DateTime  @default(now())
  clockOut  DateTime?
  status    String    // PRESENT, LATE, ABSENT
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
}

model Shift {
  id             Int             @id @default(autoincrement())
  name           String          @unique // e.g. "Morning", "Evening"
  startTime      String          // e.g. "08:00"
  endTime        String          // e.g. "16:00"
  employeeShifts EmployeeShift[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @default(now()) @updatedAt
}

model EmployeeShift {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftId   Int
  shift     Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  date      DateTime
  createdAt DateTime @default(now())
}

model Leave {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType String   // CASUAL, SICK, ANNUAL
  startDate DateTime
  endDate   DateTime
  status    String   // PENDING, APPROVED, REJECTED
  reason    String?
  approvedBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Payroll {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  month       String    // e.g. "June"
  year        Int       // e.g. 2026
  basicSalary Float
  allowances  Float     @default(0.0)
  deductions  Float     @default(0.0)
  netSalary   Float
  status      String    // PENDING, PAID
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
}
